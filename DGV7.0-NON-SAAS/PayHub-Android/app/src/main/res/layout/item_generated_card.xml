<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_service_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Card header: network logo + service info -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <ImageView android:id="@+id/iv_network_logo"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_airtime"
            android:scaleType="centerCrop"
            android:layout_marginEnd="12dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_card_network"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textStyle="bold" android:textSize="14sp"
                android:textColor="@color/text_primary" />
            <TextView android:id="@+id/tv_card_plan"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_secondary" />
        </LinearLayout>
        <TextView android:id="@+id/tv_card_price"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" android:textSize="14sp"
            android:textColor="@color/primary" />
    </LinearLayout>

    <!-- Serial number -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="S/N: " android:textSize="12sp" android:textColor="@color/text_secondary" />
        <TextView android:id="@+id/tv_card_sn"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/text_primary"
            android:textStyle="bold" android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- PIN -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PIN: " android:textSize="14sp" android:textColor="@color/text_secondary" />
        <TextView android:id="@+id/tv_card_pin"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="18sp" android:textColor="@color/primary_dark"
            android:textStyle="bold" android:letterSpacing="0.15" />
    </LinearLayout>

    <!-- Validity -->
    <TextView android:id="@+id/tv_card_validity"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="@color/text_hint"
        android:layout_marginBottom="8dp" />

    <!-- Save button -->
    <Button android:id="@+id/btn_save_card"
        android:layout_width="match_parent" android:layout_height="36dp"
        android:text="Save as Image"
        android:textSize="12sp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
