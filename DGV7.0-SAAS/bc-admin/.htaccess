# DGV6.90 — /bc-admin/.htaccess
# Clean URLs for vendor admin panel

Options -Indexes
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /bc-admin/

    # Serve clean URL → actual .php file
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)$ $1.php [L,QSA]
</IfModule>
