<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cards &amp; Crypto"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="8dp" />

        <!-- Virtual Cards Card (Blue Background) -->
        <LinearLayout
            android:id="@+id/card_virtual_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_blue"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_vcard"
                    android:background="@drawable/bg_icon_vcard"
                    android:padding="10dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Virtual Card Icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Virtual Cards"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dollar &amp; Naira for online payments"
                        android:textSize="13sp"
                        android:textColor="#BBDEFB" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_vcard_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Issue and manage virtual cards for seamless online transactions."
                android:textSize="13sp"
                android:textColor="#BBDEFB"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/btn_open_vcard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_white_pill"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage Virtual Cards ›"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Gift Cards Card (Surface Background) -->
        <LinearLayout
            android:id="@+id/card_gift_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_surface"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_giftcard"
                    android:background="@drawable/bg_icon_giftcard"
                    android:padding="10dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Gift Card Icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gift Cards"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trade local &amp; international gift cards"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_giftcard_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buy, sell and redeem local and international gift cards at the best rates."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/btn_open_giftcard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary_pill"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buy &amp; Manage Gift Cards ›"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Crypto Wallets Card (Dark Background) -->
        <LinearLayout
            android:id="@+id/card_crypto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp"
            android:layout_marginBottom="8dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_bitcoin"
                    android:background="@drawable/bg_icon_crypto"
                    android:padding="10dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Crypto Icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crypto Wallets"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send, Swap &amp; Hold Stable Coins"
                        android:textSize="13sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_crypto_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your crypto wallets — send, receive, swap stablecoins and more."
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/btn_open_crypto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_amber_pill"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open Crypto Wallets ›"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
